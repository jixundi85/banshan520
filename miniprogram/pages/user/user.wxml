<view class="user-page">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-info" wx:if="{{isLoggedIn}}">
      <image class="avatar" src="{{userInfo.avatar || '/static/images/default-avatar.png'}}" />
      <view class="info-content">
        <text class="nickname">{{userInfo.nickname}}</text>
        <text class="role tag tag-success" wx:if="{{isCreator}}">认证创作者</text>
        <text class="role tag tag-primary" wx:else>普通用户</text>
      </view>
      <view class="edit-btn" bindtap="onMenuTap" data-path="/pages/user/profile/profile">
        <image src="/static/icons/edit.png" />
        <text>编辑</text>
      </view>
    </view>
    
    <view class="user-info guest" wx:else bindtap="goLogin">
      <image class="avatar" src="/static/images/default-avatar.png" />
      <view class="info-content">
        <text class="nickname">点击登录</text>
        <text class="desc">登录后享受更多服务</text>
      </view>
    </view>
    
    <!-- 统计数据 -->
    <view class="user-stats" wx:if="{{isLoggedIn}}">
      <view class="stat-item">
        <text class="stat-num">{{userInfo.balance || 0}}</text>
        <text class="stat-label">余额</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onMenuTap" data-path="/pages/user/favorites/favorites">
        <text class="stat-num">0</text>
        <text class="stat-label">收藏</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">0</text>
        <text class="stat-label">关注</text>
      </view>
    </view>
  </view>

  <!-- 成为创作者入口 -->
  <view class="creator-banner card" wx:if="{{isLoggedIn && !isCreator}}" bindtap="becomeCreator">
    <view class="creator-content">
      <image class="creator-icon" src="/static/icons/creator.png" />
      <view class="creator-text">
        <text class="creator-title">成为认证创作者</text>
        <text class="creator-desc">分享技能，获得收入</text>
      </view>
    </view>
    <view class="creator-btn">
      <text>申请入驻</text>
      <image src="/static/icons/arrow-right.png" />
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list card">
    <view 
      class="menu-item"
      wx:for="{{menus}}"
      wx:key="title"
      bindtap="onMenuTap"
      data-path="{{item.path}}"
      data-needauth="{{item.needAuth}}"
    >
      <view class="menu-left">
        <image class="menu-icon" src="{{item.icon}}" />
        <text class="menu-title">{{item.title}}</text>
      </view>
      <view class="menu-right">
        <text class="menu-badge" wx:if="{{item.badge === 'unreadCount' && unreadCount > 0}}">{{unreadCount}}</text>
        <image class="arrow" src="/static/icons/arrow-right.png" />
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" wx:if="{{isLoggedIn}}" bindtap="onLogout">
    <text>退出登录</text>
  </view>

  <!-- 版本信息 -->
  <view class="version">
    <text>V1.0.0</text>
  </view>
</view>
