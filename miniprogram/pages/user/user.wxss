/* 用户中心样式 */

.user-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 用户信息头部 */
.user-header {
  background: linear-gradient(135deg, #4A90E2, #67C23A);
  padding: 60rpx 30rpx 80rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-info.guest {
  justify-content: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  margin-right: 24rpx;
}

.info-content {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.role {
  font-size: 22rpx;
}

.desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.edit-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
}

.edit-btn image {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.edit-btn text {
  font-size: 24rpx;
  color: #ffffff;
}

/* 用户统计数据 */
.user-stats {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 创作者入口 */
.creator-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: -40rpx 30rpx 20rpx;
  padding: 30rpx;
}

.creator-content {
  display: flex;
  align-items: center;
}

.creator-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
}

.creator-title {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.creator-desc {
  font-size: 24rpx;
  color: #999999;
}

.creator-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #4A90E2, #67C23A);
  border-radius: 30rpx;
}

.creator-btn text {
  font-size: 24rpx;
  color: #ffffff;
  margin-right: 8rpx;
}

.creator-btn image {
  width: 24rpx;
  height: 24rpx;
}

/* 菜单列表 */
.menu-list {
  margin: 20rpx 30rpx;
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}

.menu-title {
  font-size: 28rpx;
  color: #333333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-badge {
  background: #FF6B6B;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.arrow {
  width: 28rpx;
  height: 28rpx;
}

/* 退出登录 */
.logout-btn {
  margin: 40rpx 30rpx;
  text-align: center;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.logout-btn text {
  font-size: 28rpx;
  color: #FF6B6B;
}

/* 版本信息 */
.version {
  text-align: center;
  padding: 40rpx;
}

.version text {
  font-size: 22rpx;
  color: #CCCCCC;
}
