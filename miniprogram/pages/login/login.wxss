/* 登录页面样式 */

.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #4A90E2 0%, #67C23A 100%);
  padding: 100rpx 40rpx 0;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区域 */
.form-section {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 60rpx 40rpx;
  min-height: 60vh;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  height: 100rpx;
  background: #F5F5F5;
  border-radius: 50rpx;
  padding: 0 40rpx;
  margin-bottom: 30rpx;
}

.form-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
}

.placeholder {
  color: #999999;
}

/* 错误提示 */
.error-tip {
  background: rgba(245, 108, 108, 0.1);
  color: #F56C6C;
  font-size: 24rpx;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

/* 提交按钮 */
.submit-btn {
  margin-bottom: 30rpx;
}

/* 忘记密码 */
.forgot-password {
  text-align: right;
  margin-bottom: 40rpx;
}

.forgot-password text {
  font-size: 26rpx;
  color: #4A90E2;
}

/* 切换登录/注册 */
.switch-mode {
  text-align: center;
  margin-bottom: 60rpx;
}

.switch-mode text {
  font-size: 26rpx;
  color: #666666;
}

.switch-mode .link {
  color: #4A90E2;
  margin-left: 10rpx;
}

/* 分隔线 */
.divider {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #E5E5E5;
}

.divider text {
  padding: 0 30rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 微信登录按钮 */
.wechat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #07C160;
  border-radius: 44rpx;
  border: none;
}

.wechat-btn image {
  width: 44rpx;
  height: 44rpx;
  margin-right: 16rpx;
}

.wechat-btn text {
  font-size: 32rpx;
  color: #ffffff;
}

.wechat-btn::after {
  border: none;
}
