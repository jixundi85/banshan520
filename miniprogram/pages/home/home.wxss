/* 首页样式 */

.home {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #4A90E2, #67C23A);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #ffffff;
  border-radius: 36rpx;
  padding: 0 30rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.placeholder {
  color: #999999;
}

/* 轮播图 */
.banner {
  height: 320rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 快捷入口 */
.quick-nav {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 20rpx;
  background: #ffffff;
  margin-bottom: 20rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #666666;
}

/* 数据统计 */
.stats-section {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.stats-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4A90E2, #67C23A);
  border-radius: 16rpx;
  padding: 40rpx;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 区块通用样式 */
.section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  display: flex;
  align-items: center;
  color: #999999;
  font-size: 24rpx;
}

.section-more image {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
}

/* 课程卡片 */
.course-scroll {
  white-space: nowrap;
  width: 100%;
}

.course-card {
  display: inline-block;
  width: 280rpx;
  margin-right: 24rpx;
  vertical-align: top;
}

.course-cover {
  width: 280rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.course-info {
  padding: 0 8rpx;
}

.course-title {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.course-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.course-price {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: bold;
}

.course-students {
  font-size: 22rpx;
  color: #999999;
}

/* 创作者卡片 */
.creator-scroll {
  white-space: nowrap;
  width: 100%;
}

.creator-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  margin-right: 24rpx;
}

.creator-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  border: 4rpx solid #4A90E2;
}

.creator-name {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 12rpx;
  width: 100%;
  text-align: center;
}

.creator-tags {
  display: flex;
  justify-content: center;
}

/* 需求卡片 */
.demand-list {
  display: flex;
  flex-direction: column;
}

.demand-card {
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.demand-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.demand-title {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  margin-right: 20rpx;
}

.demand-budget {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: bold;
  white-space: nowrap;
}

.demand-footer {
  display: flex;
  justify-content: space-between;
}

.demand-date, .demand-views {
  font-size: 22rpx;
  color: #999999;
}

/* 登录提示 */
.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: #ffffff;
  margin-top: 20rpx;
}

.login-tip text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 30rpx;
}

.login-tip .btn {
  width: 300rpx;
}
