/* 创作者中心样式 */

.creator-page {
  min-height: 100vh;
  background: #F5F5F5;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
}

.creator-header {
  background: linear-gradient(135deg, #4A90E2, #67C23A);
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  margin-bottom: 24rpx;
}

.nickname {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.expertise {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 30rpx;
}

.stats-row {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.bio {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  line-height: 1.6;
}

.section {
  background: #ffffff;
  padding: 30rpx;
  margin-top: 20rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
}

.course-list {
  display: flex;
  flex-direction: column;
}

.course-item {
  display: flex;
  padding: 20rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.course-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.course-title {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.course-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: bold;
}

.students {
  font-size: 22rpx;
  color: #999999;
}
