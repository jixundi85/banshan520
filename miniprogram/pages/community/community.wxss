/* 社区页样式 */

.community-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

/* 帖子列表 */
.post-list {
  padding: 20rpx;
}

.post-item {
  padding: 30rpx;
}

/* 帖子头部 */
.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-header .avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.time {
  font-size: 22rpx;
  color: #999999;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 20rpx;
}

.post-title {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.post-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.post-images image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

/* 互动栏 */
.post-actions {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.action-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-item image {
  width: 36rpx;
  height: 36rpx;
  margin-right: 10rpx;
}

.action-item text {
  font-size: 24rpx;
  color: #666666;
}

/* 发布按钮 */
.publish-fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4A90E2, #67C23A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.3);
}

.publish-fab image {
  width: 48rpx;
  height: 48rpx;
}

/* 发布弹窗 */
.publish-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.publish-content {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx;
}

.publish-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.publish-header text {
  font-size: 32rpx;
  font-weight: bold;
}

.publish-header image {
  width: 40rpx;
  height: 40rpx;
}

.publish-input {
  height: 88rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.publish-textarea {
  width: 100%;
  height: 300rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.publish-content .btn {
  width: 100%;
}
