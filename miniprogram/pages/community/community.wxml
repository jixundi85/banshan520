<view class="community-page">
  <!-- 帖子列表 -->
  <view class="post-list">
    <view 
      class="post-item card"
      wx:for="{{posts}}"
      wx:key="id"
    >
      <!-- 用户信息 -->
      <view class="post-header">
        <image class="avatar" src="{{item.avatar}}" />
        <view class="user-info">
          <text class="nickname">{{item.nickname}}</text>
          <text class="time">{{item.created_at}}</text>
        </view>
      </view>
      
      <!-- 帖子内容 -->
      <view class="post-content" bindtap="goDetail" data-id="{{item.id}}">
        <text class="post-title text-ellipsis-2">{{item.title}}</text>
        <text class="post-text text-ellipsis-2">{{item.content}}</text>
        
        <!-- 图片 -->
        <view class="post-images" wx:if="{{item.images && item.images.length > 0}}">
          <image 
            wx:for="{{item.images}}" 
            wx:for-item="img"
            wx:key="index"
            src="{{img}}"
            mode="aspectFill"
          />
        </view>
      </view>
      
      <!-- 互动栏 -->
      <view class="post-actions">
        <view class="action-item" bindtap="onLike" data-id="{{item.id}}">
          <image src="/static/icons/like.png" />
          <text>{{item.like_count || 0}}</text>
        </view>
        <view class="action-item" bindtap="goDetail" data-id="{{item.id}}">
          <image src="/static/icons/comment.png" />
          <text>{{item.comment_count || 0}}</text>
        </view>
        <view class="action-item">
          <image src="/static/icons/share.png" />
          <text>分享</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{posts.length > 0}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:elif="{{!hasMore}}">没有更多了</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && posts.length === 0}}">
      <image src="/static/images/empty-post.png" mode="aspectFit" />
      <text>暂无帖子</text>
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="publish-fab" bindtap="showPublish">
    <image src="/static/icons/edit.png" />
  </view>

  <!-- 发布弹窗 -->
  <view class="publish-modal" wx:if="{{showPublishModal}}" bindtap="hidePublish">
    <view class="publish-content" catchtap="stopPropagation">
      <view class="publish-header">
        <text>发布帖子</text>
        <image src="/static/icons/close.png" bindtap="hidePublish" />
      </view>
      
      <input 
        class="publish-input"
        placeholder="标题"
        placeholder-class="placeholder"
        value="{{publishForm.title}}"
        data-field="title"
        bindinput="onInput"
      />
      
      <textarea 
        class="publish-textarea"
        placeholder="分享你的想法..."
        placeholder-class="placeholder"
        value="{{publishForm.content}}"
        data-field="content"
        bindinput="onInput"
      />
      
      <button class="btn btn-primary" bindtap="onPublish">发布</button>
    </view>
  </view>
</view>
