# ============================================
# 半山AIX 前端环境变量配置
# ============================================

# API基础地址
VITE_API_URL=http://localhost:3000/api

# 前端运行端口
VITE_PORT=8080

# 是否开启Mock数据（开发时使用）
VITE_USE_MOCK=false

# 微信支付配置
VITE_WECHAT_APPID=your-wechat-appid

# 阿里云OSS配置
VITE_OSS_DOMAIN=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
