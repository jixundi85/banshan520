# ==================== API Key 配置模板 ====================
# 复制此文件为 .env.local 并填入您的API密钥
# 文件路径：banshan520/.env.local

# ==================== OpenAI (GPT-4, DALL-E) ====================
# 获取地址：https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== Anthropic (Claude) ====================
# 获取地址：https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== Google Gemini ====================
# 获取地址：https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 通义千问（阿里云） ====================
# 获取地址：https://dashscope.console.aliyun.com/apiKey
VITE_QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 智谱GLM ====================
# 获取地址：https://open.bigmodel.cn/usercenter/apikeys
VITE_ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 豆包（火山引擎） ====================
# 获取地址：https://console.volcengine.com/ark
VITE_DOUBAO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 百度文心一言 ====================
# 获取地址：https://console.bce.baidu.com/
VITE_ERNIE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
VITE_ERNIE_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 讯飞星火 ====================
# 获取地址：https://console.xfyun.cn/
VITE_XUNFEI_APP_ID=xxxxxxxxxx
VITE_XUNFEI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
VITE_XUNFEI_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 腾讯混元 ====================
# 获取地址：https://console.cloud.tencent.com/hunyuan
VITE_HUNYUAN_SECRET_ID=xxxxxxxxxxxxxxxx
VITE_HUNYUAN_SECRET_KEY=xxxxxxxxxxxxxxxx

# ==================== Stability AI ====================
# 获取地址：https://platform.stability.ai/
VITE_STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 图像生成提供方 ====================
# 可选值：pollinations (免费) / stability / dalle
VITE_IMAGE_PROVIDER=pollinations
